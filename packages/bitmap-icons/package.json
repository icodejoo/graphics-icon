{
  "name": "bitmap-icons",
  "private": true,
  "version": "0.0.0",
  "description": "Vite plugin that packs bitmaps (png/jpg/webp/avif) into a single sprite-sheet atlas with sharp + maxrects-packer, emitting an adaptive stylesheet, an entry script (relative imports + IconName type) and optional coordinate JSON. Idempotent writes, shared on-disk cache, lazy-loaded sharp.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vite-plugin",
    "sprite-sheet",
    "spritesheet",
    "sharp",
    "maxrects",
    "webp",
    "image-atlas",
    "bitmap"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icodejoo/svg2colorfont.git",
    "directory": "packages/bitmap-icons"
  },
  "homepage": "https://github.com/icodejoo/svg2colorfont/tree/main/packages/bitmap-icons",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@codejoo/utils": "workspace:*",
    "sharp": "catalog:",
    "maxrects-packer": "catalog:"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7 || ^8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vite": "catalog:",
    "tsup": "^8.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup"
  }
}
