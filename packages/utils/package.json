{
  "name": "@codejoo/utils",
  "version": "0.0.0",
  "description": "Shared internal utilities for the @codejoo/graphics-to-font toolkit: content hashing, glob matching, idempotent writes, relative-path helpers, a shared on-disk cache (sorted JSON + pruning + shared cache folder), and SVG scaling/normalization aligned with colorfont. Subpath exports + lazy-loaded heavy deps so unused code never runs or allocates.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icodejoo/svg2colorfont.git",
    "directory": "packages/utils"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./hash": {
      "types": "./src/hash.ts",
      "import": "./src/hash.ts"
    },
    "./fingerprint": {
      "types": "./src/fingerprint.ts",
      "import": "./src/fingerprint.ts"
    },
    "./glob": {
      "types": "./src/glob.ts",
      "import": "./src/glob.ts"
    },
    "./fs-write": {
      "types": "./src/fs-write.ts",
      "import": "./src/fs-write.ts"
    },
    "./path-rel": {
      "types": "./src/path-rel.ts",
      "import": "./src/path-rel.ts"
    },
    "./cache": {
      "types": "./src/cache.ts",
      "import": "./src/cache.ts"
    },
    "./scale-svg": {
      "types": "./src/scale-svg.ts",
      "import": "./src/scale-svg.ts"
    },
    "./banner": {
      "types": "./src/banner.ts",
      "import": "./src/banner.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "test": "node --experimental-strip-types cache.test.ts"
  },
  "dependencies": {
    "scale-that-svg": "catalog:",
    "svgo": "catalog:",
    "svgpath": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0"
  }
}
